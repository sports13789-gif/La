package com.cloud;

import org.cloudbus.cloudsim.*;
import org.cloudbus.cloudsim.provisioners.*;
import java.util.*;

public class CloudScheduling {

    public static void main(String[] args) {

        try {
            CloudSim.init(1, Calendar.getInstance(), false);

            // Datacenter
            Datacenter dc = createDatacenter("DC");

            // Broker
            DatacenterBroker broker = new DatacenterBroker("Broker");
            int id = broker.getId();

            // VM
            Vm vm = new Vm(0, id, 1000, 1, 512, 1000, 10000,
                    "Xen", new CloudletSchedulerTimeShared());

            broker.submitVmList(Arrays.asList(vm));

            // Cloudlets (FCFS order)
            UtilizationModel um = new UtilizationModelFull();

            Cloudlet c1 = new Cloudlet(0, 400000, 1, 300, 300, um, um, um);
            Cloudlet c2 = new Cloudlet(1, 200000, 1, 300, 300, um, um, um);

            c1.setUserId(id);
            c2.setUserId(id);
            c1.setVmId(0);
            c2.setVmId(0);

            broker.submitCloudletList(Arrays.asList(c1, c2));

            CloudSim.startSimulation();
            CloudSim.stopSimulation();

            // Output
            for (Cloudlet c : broker.getCloudletReceivedList()) {
                System.out.println("Cloudlet " + c.getCloudletId() + " SUCCESS");
            }

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private static Datacenter createDatacenter(String name) throws Exception {

        List<Pe> peList = Arrays.asList(
                new Pe(0, new PeProvisionerSimple(1000))
        );

        Host host = new Host(0,
                new RamProvisionerSimple(2048),
                new BwProvisionerSimple(10000),
                1000000,
                peList,
                new VmSchedulerTimeShared(peList)
        );

        DatacenterCharacteristics ch = new DatacenterCharacteristics(
                "x86", "Linux", "Xen",
                Arrays.asList(host),
                10.0, 3.0, 0.05, 0.001, 0.0
        );

        return new Datacenter(name, ch,
                new VmAllocationPolicySimple(Arrays.asList(host)),
                new LinkedList<>(), 0);
    }
}
